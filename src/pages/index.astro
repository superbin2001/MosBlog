---
import '../styles/index.css';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

// 日期降序获取文章
const posts: CollectionEntry<'posts'>[] = (await getCollection('posts')).sort(
  (a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) => {
  return new Date(date).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<BaseLayout title="首页" description="MosBlog - 技术博客">
  <div class="home">
    <header class="page-header">
      <h2 class="greeting">你好，我是灰云盖雪 </h2>
      <p class="intro">
        人总是要留下点什么，随便写写吧。
      </p>
    </header>

    <section class="posts-section">
      <h3 class="section-title">最近文章</h3>
      <div class="post-list">
        {posts.slice(0,5).map((post: CollectionEntry<'posts'>) => (
          <article class="post-card">
            <a href={`/posts/${post.slug}/`} class="post-link">
              <div class="post-content">
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-description">{post.data.description}</p>
                <div class="post-meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formatDate(post.data.pubDate)}
                  </time>
                  {post.data.tags.length > 0 && (
                    <span class="post-tags">
                      {post.data.tags.join(', ')}
                    </span>
                  )}
                </div>
              </div>
              {post.data.heroImage && (
                <div class="post-image">
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.title}
                    inferSize={true}
                  />
                </div>
              )}
            </a>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
