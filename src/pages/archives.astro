---
import '../styles/archives.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');

// 按年份分组文章
const postsByYear = posts.reduce((acc, post) => {
  const year = new Date(post.data.pubDate).getFullYear();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {} as Record<string, typeof posts>);

// 按年份降序排列
const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="归档" description="MosBlog - 文章归档">
  <div class="archives-page">
    <!-- 文章列表 -->
    <div class="archives-list">
      {years.map((year) => (
        <div class="year-section" id={`year-${year}`}>
          <!-- 年份分割线 -->
          <div class="year-divider">
            <span class="year-label">{year}</span>
          </div>

          <!-- 该年份的文章列表 -->
          <div class="year-posts">
            {postsByYear[year]
              .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
              .map((post) => (
                <article class="post-item">
                  <a href={`/posts/${post.slug}/`} class="post-link">
                    <span class="post-date">
                      {new Date(post.data.pubDate).toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}
                    </span>
                    <span class="post-title">{post.data.title}</span>
                  </a>
                </article>
              ))}
          </div>
        </div>
      ))}
    </div>

    <!-- 右侧时间轴 -->
    <aside class="timeline">
      <div class="timeline-track" id="timeline-track">
        {years.map((year, index) => (
          <a
            href={`#year-${year}`}
            class="timeline-item"
            data-year={year}
            data-index={index}
            data-total={years.length}
          >
            {year}
          </a>
        ))}
      </div>
      <!-- 滑块 -->
      <div class="timeline-slider-track">
        <div class="timeline-slider" id="timeline-slider"></div>
      </div>
    </aside>
  </div>
</BaseLayout>

<script>
  // 时间轴滑块跟随滚动
  const slider = document.getElementById('timeline-slider');
  const sliderTrack = document.querySelector('.timeline-slider-track');
  const yearSections = document.querySelectorAll('.year-section');
  const timelineItems = document.querySelectorAll('.timeline-item');

  function updateSlider() {
    const scrollTop = window.scrollY;
    const windowHeight = window.innerHeight;
    const docHeight = document.documentElement.scrollHeight;

    // 计算滚动比例
    const scrollableHeight = docHeight - windowHeight;
    const scrollRatio = Math.min(Math.max(scrollTop / scrollableHeight, 0), 1);

    // 获取滑块轨道的可用高度
    if (slider && sliderTrack) {
      const trackHeight = sliderTrack.clientHeight;
      const sliderHeight = slider.clientHeight;
      const maxTop = trackHeight - sliderHeight;
      const sliderTop = maxTop * scrollRatio;
      slider.style.top = `${sliderTop}px`;
    }

    // 高亮当前年份
    let currentYear = '';
    yearSections.forEach((section) => {
      const rect = section.getBoundingClientRect();
      if (rect.top <= windowHeight / 2) {
        currentYear = section.id.replace('year-', '');
      }
    });

    timelineItems.forEach((item) => {
      if (item.getAttribute('data-year') === currentYear) {
        item.classList.add('active');
      } else {
        item.classList.remove('active');
      }
    });
  }

  window.addEventListener('scroll', updateSlider);
  updateSlider();
</script>
