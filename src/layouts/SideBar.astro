---
import '../styles/SideBar.css';
import { Image } from "astro:assets"
import avatar from "../assets/HygxAvatar.jpg"
---
<aside class="sidebar">
    <div class="profile">
        <div class="avatar">
            <Image
                priority
                src={avatar}
                alt="Avatar"
            />
        </div>
        <h1 class="name">MosBlog</h1>
        <p class="bio">一个不吵闹的的博客</p>
    </div>
    <nav class="nav">
        <a href="/">首页</a>
        <a href="/archives/">归档</a>
        <a href="/tags/">标签</a>
        <a href="/about">关于</a>
    </nav>
    <div class="social">
        <a href="https://github.com/superbin2001" target="_blank" rel="noopener">GitHub</a>
        <a href="hygx2001@gmail.com">Email</a>
    </div>
</aside>
