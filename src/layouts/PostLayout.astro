---
import type { CollectionEntry } from 'astro:content';
import SideBar from './SideBar.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags } = post.data;

const formattedDate = new Date(pubDate).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | MosBlog</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="layout">
      <!-- 左侧侧边栏 -->
      <SideBar/>

      <!-- 右侧内容区 -->
      <main class="main">
        <article class="article">
          <!-- 文章头部 -->
          <header class="article-header">
            {heroImage && <img class="hero-image" src={heroImage} alt={title} />}
            <h1 class="title">{title}</h1>
            <div class="meta">
              <time datetime={pubDate.toISOString()}>{formattedDate}</time>
              {tags.length > 0 && <span class="tags">{tags.join(', ')}</span>}
            </div>
          </header>

          <!-- 文章内容 -->
          <div class="content">
            <slot />
          </div>

          <!-- 文章底部 -->
          <footer class="article-footer">
            <div class="copyright">
              <p>本文由 MosBlog 于 {formattedDate} 发布</p>
            </div>
          </footer>
        </article>
      </main>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #ffffff;
    --color-text: #333333;
    --color-text-light: #666666;
    --color-accent: #4571ca;
    --color-border: #e5e5e5;
    --color-code-bg: #f6f8fa;
    --sidebar-width: 280px;
    --content-max-width: 800px;
    --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    --font-mono: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-bg: #1a1a2e;
      --color-text: #e0e0e0;
      --color-text-light: #a0a0a0;
      --color-accent: #6c8eea;
      --color-border: #2d2d44;
      --color-code-bg: #252538;
    }
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-sans);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
  }

  body {
    min-height: 100vh;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  a:hover {
    opacity: 0.8;
  }

  .layout {
    display: flex;
    min-height: 100vh;
  }

  /* 侧边栏 */
  .sidebar {
    width: var(--sidebar-width);
    padding: 2rem;
    border-right: 1px solid var(--color-border);
    position: fixed;
    height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: var(--color-bg);
  }

  .profile {
    text-align: center;
    margin-bottom: 2rem;
  }

  .avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto 1rem;
    border: 3px solid var(--color-accent);
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .name {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .bio {
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  .nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .nav a {
    color: var(--color-text);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    transition: background-color 0.2s, color 0.2s;
  }

  .nav a:hover {
    background-color: var(--color-code-bg);
    opacity: 1;
  }

  .social {
    margin-top: auto;
    display: flex;
    gap: 1rem;
    justify-content: center;
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  /* 主内容区 */
  .main {
    flex: 1;
    margin-left: var(--sidebar-width);
    padding: 3rem 2rem;
    max-width: calc(100vw - var(--sidebar-width));
  }

  .article {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .article-header {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-image {
    width: 100%;
    border-radius: 12px;
    margin-bottom: 1.5rem;
  }

  .title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .meta {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  .tags {
    color: var(--color-accent);
  }

  /* 文章内容样式 */
  .content {
    line-height: 1.8;
  }

  .content h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 1.5rem 0 0.75rem;
  }

  .content p {
    margin-bottom: 1rem;
  }

  .content ul, .content ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .content li {
    margin-bottom: 0.5rem;
  }

  .content code {
    font-family: var(--font-mono);
    background-color: var(--color-code-bg);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .content pre {
    background-color: var(--color-code-bg);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .content pre code {
    background: none;
    padding: 0;
  }

  .content blockquote {
    border-left: 4px solid var(--color-accent);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text-light);
    font-style: italic;
  }

  .content img {
    max-width: 100%;
    border-radius: 8px;
    margin: 1rem 0;
  }

  .content a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
  }

  .content th, .content td {
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    text-align: left;
  }

  .content th {
    background-color: var(--color-code-bg);
  }

  /* 文章底部 */
  .article-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .copyright {
    font-size: 0.875rem;
    color: var(--color-text-light);
    text-align: center;
  }

  /* 响应式设计 */
  @media (max-width: 768px) {
    .layout {
      flex-direction: column;
    }

    .sidebar {
      position: relative;
      width: 100%;
      height: auto;
      padding: 1.5rem;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }

    .main {
      margin-left: 0;
      max-width: 100vw;
      padding: 1.5rem;
    }

    .title {
      font-size: 1.5rem;
    }
  }
</style>
