---
import '../styles/global.css';
import '../styles/PostLayout.css';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import SideBar from './SideBar.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags } = post.data;

const formattedDate = new Date(pubDate).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | MosBlog</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="layout">
      <!-- 左侧侧边栏 -->
      <SideBar/>

      <!-- 右侧内容区 -->
      <main class="main">
        <article class="article">
          <!-- 文章头部 -->
          <header class="article-header">
            {heroImage && (
              <Image
                class="hero-image"
                src={heroImage}
                alt={title}
                inferSize={true}
              />
            )}
            <h1 class="title">{title}</h1>
            <div class="meta">
              <time datetime={pubDate.toISOString()}>{formattedDate}</time>
              {tags.length > 0 && <span class="tags">{tags.join(', ')}</span>}
            </div>
          </header>

          <!-- 文章内容 -->
          <div class="content">
            <slot />
          </div>

          <!-- 文章底部 -->
          <footer class="article-footer">
            <div class="copyright">
              <p>本文由 MosBlog 于 {formattedDate} 发布</p>
            </div>
          </footer>
        </article>
      </main>
    </div>
  </body>
</html>
